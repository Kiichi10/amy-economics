      "duration": 2.7306666666666666,
      "speaker": "shonen",
      "speaker_display": "少年",
      "text": "えっ、中国とイランって仲良かったんじゃないっすか？",
      "emotion": "normal",
      "voicevox_speaker_id": 12,
      "sentence_timings": [
        {
          "text": "えっ、中国とイランって仲良かったんじゃないっすか？",
          "duration": 2.730667,
          "offset": 0.0
        }
      ]
    },
    {
      "index": 3,
