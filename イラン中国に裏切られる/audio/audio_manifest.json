      "duration": 2.6666666666666665,
      "speaker": "shonen",
      "speaker_display": "少年",
      "text": "60兆円の同盟を裏切るって何があったんすか！",
      "emotion": "normal",
      "voicevox_speaker_id": 12,
      "sentence_timings": [
        {
          "text": "60兆円の同盟を裏切るって何があったんすか！",
